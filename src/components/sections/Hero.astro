---
import DecorativeSquares from '../ui/DecorativeSquares.astro';
import { site } from '../../data/site';

const { title = site.author, label = 'Portfolio' } = Astro.props;
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <!-- TODO: Replace placeholder hero content with confirmed cover image and introductory copy. -->
  <DecorativeSquares />
  <p class="hero__label">{label}</p>
  <h1 id="hero-title">{title}</h1>
</section>
